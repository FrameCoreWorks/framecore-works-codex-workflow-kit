{
  "schema_version": 1,
  "artifacts": {
    "Task Confirmation": {
      "required_fields": [
        "confirmed_goal",
        "excluded_scope",
        "work_mode",
        "expected_output",
        "immediate_next_step"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/task-confirmation.md"
      ]
    },
    "Project State": {
      "required_fields": [
        "workflow_blueprint",
        "active_roles",
        "completed_or_existing_artifacts",
        "required_handoffs",
        "review_gates",
        "next_role",
        "next_action"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/project-state.md"
      ]
    },
    "Brief Contract": {
      "required_fields": [
        "objective",
        "audience",
        "deliverables",
        "constraints",
        "exclusions",
        "unknowns",
        "acceptance_criteria"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/brief-contract.md"
      ]
    },
    "Reference Pack": {
      "required_fields": [
        "canonical_references",
        "aliases",
        "continuity_anchors",
        "suppression_rules",
        "conflicts",
        "source_notes"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/reference-pack.md"
      ]
    },
    "Evidence Note": {
      "required_fields": [
        "question",
        "sources",
        "freshness",
        "confidence",
        "limits",
        "unresolved_unknowns"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/evidence-note.md"
      ]
    },
    "Instruction Packet": {
      "required_fields": [
        "packet_id",
        "target_role",
        "goal",
        "context",
        "exclusions",
        "required_inputs",
        "method",
        "evidence_rules",
        "acceptance_criteria",
        "output_schema",
        "handoff_to"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/instruction-packet.md"
      ]
    },
    "Direction Contract": {
      "required_fields": [
        "thesis",
        "system",
        "constraints",
        "asset_matrix",
        "handoff_needs"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/direction-contract.md"
      ]
    },
    "Storyboard Contract": {
      "required_fields": [
        "beats",
        "scenes",
        "shot_cards",
        "timing",
        "continuity"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/storyboard-contract.md"
      ]
    },
    "Board Artifact Prompt": {
      "required_fields": [
        "panel_count",
        "panel_hierarchy",
        "exact_board_text",
        "shot_labels",
        "safe_margins",
        "visual_style",
        "acceptance_criteria"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/board-artifact-prompt.md"
      ]
    },
    "Copy Pack": {
      "required_fields": [
        "headlines",
        "body_copy",
        "VO",
        "dialogue",
        "supers",
        "CTA",
        "exact_text_locks"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/copy-pack.md"
      ]
    },
    "Prompt Pack": {
      "required_fields": [
        "prompts",
        "constraints",
        "expected_observables",
        "acceptance_criteria"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/prompt-pack.md"
      ]
    },
    "Image Prompt Contract": {
      "required_fields": [
        "model_policy",
        "exact_visible_text",
        "final_prompt",
        "negative_constraints",
        "QA_checks"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/image-prompt-contract.md"
      ]
    },
    "Tool Routing Plan": {
      "required_fields": [
        "selected_tool",
        "approval_status",
        "required_inputs",
        "cost_note",
        "risk_note",
        "output_plan",
        "handoff_to"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/tool-routing-plan.md"
      ]
    },
    "Execution Manifest": {
      "required_fields": [
        "tool",
        "params_summary",
        "source_assets",
        "output_files",
        "redaction_status",
        "errors",
        "next_handoff"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/execution-manifest.md"
      ]
    },
    "HyperFrames Production Brief": {
      "required_fields": [
        "composition_goal",
        "scene_structure",
        "timing",
        "animation_system",
        "caption_or_overlay_plan",
        "render_constraints",
        "QA_checks",
        "handoff_to"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/hyperframes-production-brief.md"
      ]
    },
    "Asset Manifest": {
      "required_fields": [
        "files",
        "versions",
        "sources",
        "checksums",
        "excluded_files",
        "traceability_notes"
      ],
      "example_paths": [
        "examples/contract-fixtures/artifacts/asset-manifest.md"
      ]
    },
    "QA / Iteration Report": {
      "required_fields": [
        "accepted_assets",
        "excluded_assets",
        "defects",
        "corrected_instruction_packets",
        "rerun_guidance",
        "allowlist"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/qa-iteration-report.md"
      ]
    },
    "Delivery Manifest": {
      "required_fields": [
        "final_files",
        "QA_status",
        "excluded_files",
        "source_list",
        "usage_notes",
        "known_caveats"
      ],
      "example_paths": [
        "examples/end-to-end-creative-workflow/artifacts/delivery-manifest.md"
      ]
    }
  }
}
