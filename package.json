{
  "name": "framecore-works-codex-workflow-kit",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "FrameCore Works: Creative Workflow Skill Kit for Codex.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FrameCoreWorks/framecore-works-codex-workflow-kit.git"
  },
  "bugs": {
    "url": "https://github.com/FrameCoreWorks/framecore-works-codex-workflow-kit/issues"
  },
  "homepage": "https://github.com/FrameCoreWorks/framecore-works-codex-workflow-kit#readme",
  "keywords": [
    "codex",
    "workflow",
    "skills",
    "agents",
    "creative-workflow",
    "storyboard",
    "video",
    "ecommerce",
    "prompting"
  ],
  "packageManager": "npm@10.9.2",
  "files": [
    ".editorconfig",
    ".gitattributes",
    ".agents/",
    ".codex/",
    "AGENTS.template.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md",
    "config/",
    "docs/",
    "examples/",
    "scripts/",
    "tests/"
  ],
  "bin": {
    "framecore-doctor": "./scripts/doctor.mjs",
    "framecore-guided-install": "./scripts/guided-install.mjs",
    "framecore-install": "./scripts/install.mjs",
    "framecore-onboard": "./scripts/onboard.mjs",
    "framecore-validate": "./scripts/validate.mjs"
  },
  "scripts": {
    "audit:privacy": "node scripts/audit-privacy.mjs",
    "cleanup:appledouble": "node scripts/cleanup-appledouble.mjs",
    "doctor": "node scripts/doctor.mjs",
    "install:guided": "node scripts/guided-install.mjs",
    "install:dry-run": "node scripts/install.mjs --mode dry-run",
    "onboard:defaults": "node scripts/onboard.mjs --defaults",
    "package:audit": "node scripts/package-audit.mjs",
    "package:list": "node scripts/package-list.mjs",
    "render:agents": "node scripts/render-agents.mjs",
    "release:readiness": "node scripts/release-readiness.mjs",
    "release:check": "npm run check && npm run smoke:install && npm run package:audit && npm run release:readiness",
    "secret:scan": "node scripts/safety-scan.mjs",
    "smoke:install": "node scripts/smoke-install.mjs",
    "test": "node --test",
    "validate": "node scripts/validate.mjs",
    "check": "npm run audit:privacy && npm run secret:scan && npm run validate && npm test"
  },
  "engines": {
    "node": ">=20"
  }
}
